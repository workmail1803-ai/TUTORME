# ===========================================================================
# TutorTrack environment variables
# Copy this file to `.env` and fill in real values.
# ===========================================================================

# --- Database -------------------------------------------------------------
# Supabase: Project Settings → Database → Connection string (URI).
# Use the pooled connection (port 6543) for DATABASE_URL in serverless,
# and the direct connection (port 5432) for DIRECT_URL used by migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Clerk authentication -------------------------------------------------
# https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
# Clerk Dashboard → Webhooks → add endpoint /api/webhooks/clerk → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxx"

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- (Phase 2) Supabase Storage for attachments ---------------------------
# NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="xxx"
# SUPABASE_SERVICE_ROLE_KEY="xxx"

# --- (Phase 2) Firebase Cloud Messaging for push notifications ------------
# NEXT_PUBLIC_FIREBASE_CONFIG="{...}"
# FIREBASE_SERVICE_ACCOUNT="{...}"
